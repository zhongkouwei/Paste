{
  "name": "paste-easy",
  "version": "0.1.0",
  "description": "A macOS clipboard history app inspired by Paste.",
  "productName": "Paste Easy",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "node scripts/build-mac-dir.js",
    "build:zip": "npm run build && ditto -c -k --sequesterRsrc --keepParent \"release/mac-arm64/Paste Easy.app\" \"release/Paste Easy-${npm_package_version}-arm64.zip\""
  },
  "keywords": [
    "clipboard",
    "macos",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.zhongkouwei.pastelike",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json",
      "package-lock.json",
      "!node_modules/.cache/**/*"
    ],
    "asar": true,
    "mac": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "LSUIElement": true
      },
      "target": [
        "dir"
      ]
    }
  }
}
