{
  "name": "paste-like",
  "version": "0.1.0",
  "description": "A macOS clipboard history app inspired by Paste.",
  "productName": "Paste Like",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js",
    "build": "electron-builder --mac dir",
    "build:zip": "electron-builder --mac zip"
  },
  "keywords": [
    "clipboard",
    "macos",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.zhongkouwei.pastelike",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json",
      "package-lock.json",
      "!node_modules/.cache/**/*"
    ],
    "asar": true,
    "mac": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "LSUIElement": true
      },
      "target": [
        "dir"
      ]
    }
  }
}
